            "console": "integratedTerminal",
            "env": {
                "ENV_ID": "cylinder_game",
                "TRAIN_TIME_LIMIT": "60"
            },
            "python": "${workspaceFolder}/deepcube/.venv/bin/python",
            "cwd": "${workspaceFolder}/deepcube"
        }
    ]
